{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kyler505/codex-axi/compatibility/output-schema.json",
  "title": "codex-axi representative output document",
  "type": "object",
  "minProperties": 1,
  "anyOf": [
    {"required": ["error", "code", "help"]},
    {"required": ["schema_version", "sequence", "method", "payload"]},
    {"required": ["runtime", "status"]},
    {"required": ["workspace", "tasks", "workers"]},
    {"required": ["task"]},
    {"required": ["worker"]},
    {"required": ["setup"]},
    {"required": ["returned", "total", "has_more"]},
    {"required": ["count"]}
  ],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "method": {"type": "string", "minLength": 1},
    "code": {"type": "string", "minLength": 1},
    "returned": {"type": "integer", "minimum": 0},
    "total": {"type": ["integer", "null"], "minimum": 0},
    "has_more": {"type": "boolean"}
  },
  "additionalProperties": true
}
